# ───────────────────────────────────────────────────────────────
#  SECRETS — never commit these
# ───────────────────────────────────────────────────────────────
# Real credentials live in config.js locally. Use config.example.js
# as the template for what config.js should look like, with real
# values filled in only on each developer's machine.
config.js

# One-shot bake script — contains plaintext creds when present
bake.js

# Local backup snapshots
*.bak.*

# Generic secret file patterns
.env
.env.*
*.local
secrets.json
credentials.json

# ───────────────────────────────────────────────────────────────
#  Editor / OS noise
# ───────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ───────────────────────────────────────────────────────────────
#  Build / dependency artifacts
# ───────────────────────────────────────────────────────────────
# node_modules: large, regenerable via `npm install`
node_modules/
# dist/ IS committed — GitHub Pages serves dist/tailwind.css directly
build/
.cache/

# package-lock.json captures the exact Tailwind toolchain version
# so collaborators get reproducible builds. Keep it tracked.
